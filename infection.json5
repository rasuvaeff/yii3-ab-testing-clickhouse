{
    "$schema": "vendor/infection/infection/resources/schema.json",
    "source": {
        "directories": ["src"]
    },
    "logs": {
        "text": "php://stderr",
        "summary": "build/infection-summary.log"
    },
    "phpUnit": {
        "configDir": "."
    },
    // 96% is the honest ceiling: the only survivors are two equivalent mutants —
    // `count($buffer) > $max` vs `>= $max` in the trackers' buffer-cap. At
    // count == $max, `array_slice($buffer, -$max)` returns the same $max elements
    // either way, so the two operators are behaviourally identical.
    "minMsi": 96,
    "mutators": {
        "@default": true
    }
}
